# Manifest for the alloy log agent (native install).
# Path layout (server-side, relative to CONTENT_ROOT):
#   alloy/modules/fleet_*.alloy       — shared by all hosts
#   alloy/hosts/<hostname>/config.alloy — per-host
#
# __HOST__ is substituted with the short hostname at sync time.
# The validate command runs with FLEET_STAGE and FLEET_HOST exported.

alloy/modules/fleet_levels.alloy     /etc/alloy/modules/fleet_levels.alloy
alloy/modules/fleet_journald.alloy   /etc/alloy/modules/fleet_journald.alloy
alloy/modules/fleet_docker.alloy     /etc/alloy/modules/fleet_docker.alloy
alloy/modules/fleet_drops.alloy      /etc/alloy/modules/fleet_drops.alloy
alloy/hosts/__HOST__/config.alloy    /etc/alloy/config.alloy

# Validate the in-place file. Note this validates the OLD file (the new
# file is moved into place AFTER validate runs). It catches an already-
# poisoned config; broken NEW configs are caught when the reload below
# fails alloy's own startup parse → fleet-sync rolls back.
validate:    /usr/bin/alloy fmt /etc/alloy/config.alloy

# Reload via SIGHUP — alloy reloads config in place, no service restart,
# no log gap.
reload:      systemctl reload alloy

# Ping a healthcheck so "host hasn't synced in N hours" is a visible signal.
# Replace with the UUID you create for this host.
# healthcheck: https://hc.mees.st/ping/REPLACE-WITH-UUID
